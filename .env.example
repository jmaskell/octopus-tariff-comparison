# Octopus Energy API credentials
# Copy this file to .env and fill in your API key.

# Your API key from the Octopus dashboard:
#   https://octopus.energy/dashboard/new/accounts/personal-details/api-access
# Looks like: sk_live_xxxxxxxxxxxxxxxxxxxxxxxx
OCTOPUS_API_KEY=

# Your account number (starts with "A-")
OCTOPUS_ACCOUNT=A-XXXXXXXX
